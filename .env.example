# Server-only secrets. Set these in the private deployment; never expose them with VITE_ prefixes.
OPENAI_API_KEY=
AUDIT_ACCESS_CODE=

# Cost-controlled Build Week defaults.
OPENAI_MODEL=gpt-5.6-luna
OPENAI_REASONING_EFFORT=none
AUDIT_MAX_RUNS_PER_HOUR=2
AUDIT_MAX_ACCESS_ATTEMPTS_PER_HOUR=10
JUDGE_CONCURRENCY=4

# Optional comma-separated origins for a separately hosted private frontend.
# Same-origin Vercel deployments are allowed automatically.
ALLOWED_ORIGINS=

# Leave this unset for the public GitHub Pages build so paid judging stays disabled.
# VITE_AUDIT_API_URL=https://private-judge.example/api/audit
